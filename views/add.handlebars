<h1>Add Employee</h1>

{{#if error}}
<p style="color:red;">{{error}}</p>
{{/if}}

<form method="POST" action="/add">
    <label>Name:</label>
    <input type="text" name="name" />
    <br /><br />

    <label>Phone:</label>
    <input type="text" name="phone" />
    <br /><br />

    <button type="submit">Add</button>
</form>

<br />
<a href="/">Back</a>